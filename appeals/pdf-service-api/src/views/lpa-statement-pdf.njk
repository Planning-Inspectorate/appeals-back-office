<!DOCTYPE html>
<html lang="en" class="govuk-template">
<head>
  <meta charset="utf-8" />
  <title>LPA Statement - {{ lpaStatementData.appealReference | default('N/A') }}</title>
  {% if gdsCss %}<style>{{ gdsCss | safe }}</style>{% endif %}
  <style>
    body { font-family: Arial, Helvetica, sans-serif; margin: 15mm; font-size: 9pt; line-height: 1.3; color: #333;}
    .logo { max-width: 100px; height: auto; margin-bottom: 10px; }
    .header-container { display: flex; align-items: center; margin-bottom: 10px; border-bottom: 5px solid #00703c; padding-bottom: 10px; }
    .header-text { font-size: 14pt; font-weight: bold; margin-left: 15px; }
    .beta-banner { background-color: #f3f2f1; padding: 8px 12px; margin-bottom: 15px; border: 1px solid #b1b4b6; font-size: 9pt; }
    .beta-banner strong { font-weight: bold; color: #505a5f; }
    .beta-banner .feedback-link { color: #005ea5; text-decoration: underline; }

    h1 { font-size: 16pt; margin-bottom: 10px; color: #003078; border-bottom: 1px solid #ccc; padding-bottom: 3px;}
    h2 { font-size: 13pt; margin-top: 20px; margin-bottom: 8px; color: #003078; }
    h3 { font-size: 11pt; font-weight: bold; margin-top: 15px; margin-bottom: 5px; color: #0b0c0c;}
    p { margin-bottom: 10px; }
    .not-available { color: #505a5f; font-style: italic; }
    .statement-text-block { margin-top: 5px; padding: 10px; background-color: #f8f8f8; border: 1px solid #e1e4e7;}
    .meta-info { font-size: 0.9em; color: #505a5f; margin-bottom: 15px; border-bottom: 1px solid #e1e4e7; padding-bottom: 10px;}
    .document-list { margin-top: 5px; padding-left: 0; list-style: none; }
    .document-list li { margin-bottom: 3px; }
    .site-address-header { margin-bottom: 15px; }
  </style>
</head>
<body class="govuk-body">
  <div class="header-container">
    {% if logoDataUri %}<img src="{{ logoDataUri }}" alt="Logo" class="logo">{% endif %}
    <div class="header-text">Planning Inspectorate - Manage your appeals</div>
  </div>
  <div class="beta-banner">
    <strong>BETA</strong> This is a new service - your <span class="feedback-link">feedback</span> will help us improve it.
  </div>

  <h1 class="govuk-heading-xl">LPA Statement</h1>

  <div class="site-address-header">
    <p><strong>Site address:</strong>
    {% if lpaStatementData.appealSite %}
        {{ lpaStatementData.appealSite.addressLine1 | default('') }}{% if lpaStatementData.appealSite.addressLine2 %}, {{ lpaStatementData.appealSite.addressLine2 }}{% endif %}{% if lpaStatementData.appealSite.town %}, {{ lpaStatementData.appealSite.town }}{% endif %}, {{ lpaStatementData.appealSite.postCode | default('') }}
    {% else %}
        <span class="not-available">Site address not available.</span>
    {% endif %}
    </p>
  </div>

  <p><strong>Appeal Reference:</strong> {{ lpaStatementData.appealReference | default('N/A') }}</p>

  {# Use simpler headings and paragraphs instead of summary list for better PDF rendering #}
  {% if lpaStatementData %}
    <div class="meta-info">
      <strong>Date Received:</strong> {{ lpaStatementData.created | date('d MMMM yyyy, HH:mm') if lpaStatementData.created else 'N/A' }}<br>
      <strong>Status:</strong> {{ lpaStatementData.status | default('N/A') }}
    </div>

    <h2 class="govuk-heading-m">Statement</h2>
    <div class="statement-text-block">
        <p class="govuk-body">{{ lpaStatementData.originalRepresentation | nl2br | default('No statement text provided.') | safe }}</p>
    </div>

    <h2 class="govuk-heading-m" style="margin-top: 30px;">Supporting documents</h2>
    {% if lpaStatementData.attachments and lpaStatementData.attachments.length %}
      <ul class="govuk-list document-list">
        {% for doc in lpaStatementData.attachments %}
          <li>{{ doc.name | default('Unnamed document') }}</li>
        {% endfor %}
      </ul>
    {% else %}
      <p class="not-available">No documents</p>
    {% endif %}

  {% else %}
    <p class="not-available">No LPA statement found or submitted for this appeal.</p>
  {% endif %}

</body>
</html>
