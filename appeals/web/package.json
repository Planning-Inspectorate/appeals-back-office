{
  "name": "@pins/appeals.web",
  "version": "0.0.0",
  "private": true,
  "description": "PINS Back Office Appeals Web App",
  "engines": {
    "node": ">=22 < 23"
  },
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production npm-run-all --silent sass rollup",
    "build:release": "cross-env NODE_ENV=production APP_RELEASE=true npm-run-all --silent sass rollup",
    "clean": "rimraf .turbo node_modules dist",
    "clean:dev": "rimraf dist src/server/static/scripts src/server/static/styles",
    "dev": "cross-env NODE_ENV=local npm-run-all --silent clean:dev sass rollup --parallel --race watch:** nodemon",
    "lint:js": "npx eslint .",
    "lint:js:fix": "npx eslint . --fix",
    "nodemon": "nodemon --config ./nodemon.json ./src/server/server.js",
    "rollup": "node ./scripts/rollup/bundle-js.js",
    "sass": "node ./scripts/rollup/compile-css.js",
    "start": "node ./src/server/server.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules --expose-gc\" npx jest --logHeapUsage --ci",
    "test:update": "cross-env NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules --expose-gc\" npx jest -u --logHeapUsage --ci",
    "test:watch": "npm run test -- --watch",
    "test:debug:leaks": "npm run test -- --runInBand --detectOpenHandles --logHeapUsage --verbose",
    "test:cov": "cross-env NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules --expose-gc\" npx jest --logHeapUsage --ci --coverage --forceExit",
    "tscheck": "npx tsc -p jsconfig.json --maxNodeModuleJsDepth 0",
    "watch:rollup": "chokidar \"src/client/**/*.js\" --silent -c \"npm run rollup\"",
    "watch:sass": "chokidar \"src/styles/**/*.scss\" --silent -c \"npm run sass\""
  },
  "dependencies": {
    "@azure/msal-common": "16.11.0",
    "@azure/msal-node": "^5.3.1",
    "@azure/storage-blob": "^12.33.0",
    "@hapi/boom": "10.0.1",
    "@pins/blob-storage-client": "^0.0.0",
    "@pins/express": "^0.0.0",
    "@pins/platform": "^0.0.0",
    "@types/archiver": "^8.0.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-beep": "^1.0.3",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-virtual": "^3.0.2",
    "accessible-autocomplete": "^3.0.1",
    "applicationinsights": "^3.15.1",
    "archiver": "^8.0.0",
    "body-parser": "2.3.0",
    "classnames": "^2.5.1",
    "compression": "1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "cypress": "15.18.0",
    "date-fns": "4.4.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "express-request-id": "3.0.0",
    "express-session": "1.19.0",
    "express-validator": "7.3.2",
    "form-data": "4.0.6",
    "got": "^15.1.0",
    "govuk-frontend": "6.3.0",
    "helmet": "8.2.0",
    "humps": "^2.0.1",
    "joi": "^18.2.3",
    "kleur": "4.1.5",
    "lodash-es": "^4.18.1",
    "morgan": "1.11.0",
    "node-cache": "^5.1.2",
    "node-schedule": "^2.1.1",
    "nunjucks": "^3.2.4",
    "pino": "10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pluralize": "8.0.0",
    "redis": "^6.1.0",
    "regenerator-runtime": "^0.14.1",
    "response-time": "2.3.4",
    "serve-static": "2.2.1",
    "slugify": "^1.6.9",
    "cross-env": "^10.1.0",
    "rollup": "^4.59.0",
    "rollup-plugin-iife": "^0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "npm-run-all": "^4.1.5",
    "autoprefixer": "^10.5.2",
    "signale": "1.4.0",
    "terser": "^5.48.0",
    "figures": "^6.1.0",
    "@faker-js/faker": "10.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.17.10",
    "@babel/preset-env": "^7.26.9",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.4.3",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/date-fns": "^2.6.0",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^5.0.6",
    "@types/express-request-id": "^3.0.2",
    "@types/express-session": "^1.19.0",
    "@types/humps": "^2.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node-schedule": "^2.1.8",
    "@types/nunjucks": "^3.2.6",
    "@types/pluralize": "^0.0.33",
    "@types/regenerator-runtime": "^0.13.1",
    "@types/response-time": "^2.3.9",
    "@types/signale": "^1.4.7",
    "@types/supertest": "^2.0.12",
    "chokidar-cli": "^3.0.0",
    "core-js": "^3.45.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "nock": "^14.0.16",
    "node-mocks-http": "^1.14.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.31",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0"
  },
  "imports": {
    "#environment/*": "./environment/*",
    "#app/*": "./src/server/app/*",
    "#appeals/*": "./src/server/appeals/*",
    "#lib/*": "./src/server/lib/*",
    "#testing/*": "./testing/*",
    "#common/*": "./src/common/*"
  }
}
